# ── Frontend (multi-stage) ────────────────────────────────────────────────────

# Stage 1 – build
FROM node:20-alpine AS builder

WORKDIR /app/frontend

COPY frontend/package.json frontend/package-lock.json* ./
RUN npm ci

COPY frontend/ ./

# Optional build-time API URL (leave empty to use the nginx proxy below)
ARG VITE_API_URL=""
ENV VITE_API_URL=$VITE_API_URL

RUN npm run build

# Stage 2 – serve with nginx + proxy to backend
FROM nginx:alpine

# Remove default nginx config
RUN rm /etc/nginx/conf.d/default.conf

# Nginx config: serve static assets and proxy /api → backend:8000
COPY <<'EOF' /etc/nginx/conf.d/llm-council.conf
server {
    listen 80;

    # Serve the built React app
    root /usr/share/nginx/html;
    index index.html;

    location / {
        try_files $uri $uri/ /index.html;
    }

    # Proxy API calls to the FastAPI backend
    location /api/ {
        proxy_pass         http://backend:8000/api/;
        proxy_http_version 1.1;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   Upgrade           $http_upgrade;
        proxy_set_header   Connection        "upgrade";
        # Increase timeouts for long-running LLM requests
        proxy_read_timeout 300s;
        proxy_send_timeout 300s;
    }
}
EOF

COPY --from=builder /app/frontend/dist /usr/share/nginx/html

EXPOSE 80
